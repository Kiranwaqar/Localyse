PORT=5000
NODE_ENV=development
MONGO_URI=your-mongodb-atlas-uri
TAVILY_API_KEY=your-tavily-api-key

# Groq (OpenAI-compatible API) — fuses spreadsheet rollups + Tavily + weather into offer synthesis.
# Free tier: https://console.groq.com
GROQ_API_KEY=your-groq-api-key
# Optional override (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: set to your deployed frontend domain in production.
CORS_ORIGIN=http://localhost:8080

# Google Sign-In (Web client ID from Google Cloud Console; must match VITE_GOOGLE_CLIENT_ID on the frontend).
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Base URL of the web app (verification links in emails). On Vercel you can omit if VERCEL_URL is set.
FRONTEND_URL=https://your-app.vercel.app
# Public URL of this API (approve/decline links in the merchant-request email). Required in production.
# Example: https://localyse-api.onrender.com
# API_PUBLIC_URL=

# Email delivery for coupon and budget-fit notifications.
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Localyse <your-smtp-user>

# Merchant approval (invite-only sign up). You receive application emails here; optional override.
MERCHANT_ADMIN_EMAIL=shamaiemshabbir3@gmail.com
# Required for GET/POST admin routes: list applications, approve, reject. Use a long random string in production.
MERCHANT_ADMIN_KEY=change-me-to-a-long-random-secret
# Dev only: skip the approval database check (do not set in production).
# MERCHANT_APPROVAL_BYPASS=true
