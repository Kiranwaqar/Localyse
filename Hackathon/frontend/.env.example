# Local dev: point to your Express server. On Vercel (same-origin API), leave empty or set to your live site URL.
# Do NOT set this to localhost on Vercel — verification and auth will break in production.
VITE_API_URL=http://localhost:5000
VITE_GEOAPIFY_API_KEY=your-geoapify-api-key

# Google Sign-In (same Web client ID as GOOGLE_CLIENT_ID in the backend .env)
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
