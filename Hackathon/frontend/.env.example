# Local dev: leave empty to use Vite’s /api proxy to the backend (port 5000). Set http://localhost:5000 only if you skip the proxy.
# On Vercel (same-origin API), leave empty. Do NOT set localhost on Vercel.
VITE_API_URL=
VITE_GEOAPIFY_API_KEY=your-geoapify-api-key

# Google Sign-In (same Web client ID as GOOGLE_CLIENT_ID in the backend .env)
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
